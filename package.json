{
  "name": "dog-table",
  "version": "1.3.3",
  "description": "Vanilla JavaScript data table with search, sorting, remote data, inline editing, live sync, and create workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArRahmaan17/dog-table.git"
  },
  "bugs": {
    "url": "https://github.com/ArRahmaan17/dog-table/issues"
  },
  "homepage": "https://arrahmaan17.github.io/dog-table/",
  "type": "module",
  "main": "./dist/data-table.js",
  "module": "./dist/data-table.js",
  "unpkg": "./dist/data-table.min.js",
  "jsdelivr": "./dist/data-table.min.js",
  "exports": {
    ".": {
      "import": "./dist/data-table.js",
      "default": "./dist/data-table.js"
    },
    "./min": "./dist/data-table.min.js",
    "./css": "./dist/data-table.css",
    "./css/min": "./dist/data-table.min.css",
    "./locale/*": "./dist/locale/*.js",
    "./plugin/*": "./dist/plugin/*.js",
    "./utils": "./dist/utils/index.js"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node scripts/build.mjs --clean",
    "prepack": "npm run build",
    "test": "npm run build && node --check dist/data-table.js && node --check dist/data-table.min.js"
  },
  "keywords": [
    "datatable",
    "table",
    "grid",
    "vanilla-js",
    "pagination",
    "sorting",
    "remote-data",
    "inline-editing",
    "live-sync",
    "crud"
  ],
  "author": "doglex",
  "license": "MIT"
}
